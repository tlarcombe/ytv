# ─── Entry point ─────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="ytv",
        description="Terminal YouTube viewer — browse and play via fzf and mpv",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
fzf keybindings (browse / panel):
  ENTER       Play selected video(s) with mpv
  CTRL-A      Audio-only playback
  CTRL-Y      Copy URL(s) to clipboard
  CTRL-S      Search YouTube (browse mode)
  CTRL-N      More videos from this channel (browse mode)
  CTRL-R      Refresh all feeds (browse mode)
  CTRL-B      Subscribe to channel (search / channel panel)
  TAB         Toggle multi-select
  ESC         Quit

Examples:
  ytv                      Browse subscription feed
  ytv -r                   Refresh feeds then browse
  ytv search linux tips    Search YouTube
  ytv add @Fireship        Subscribe to a channel by handle
  ytv add                  Subscribe interactively (search or URL)
  ytv remove               Unsubscribe via fzf picker
  ytv subs                 List subscriptions
  ytv import subs.opml     Import from OPML / JSON / text file
  ytv config               Show configuration
  ytv init-config          Write editable config.json
""",
    )
    parser.add_argument("--version", action="version", version=f"ytv {VERSION}")

    # Top-level flags (apply to default browse action)
    parser.add_argument("--refresh", "-r", action="store_true", help="Force-refresh feeds")
    parser.add_argument("--audio",   "-a", action="store_true", help="Audio-only playback")
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose output")

    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("browse", help="Browse feed (default)")

    sp = sub.add_parser("search", help="Search YouTube")
    sp.add_argument("query", nargs="*", help="Search terms")

    ap = sub.add_parser("add", help="Subscribe to a channel")
    ap.add_argument("channel", nargs="?", help="URL, @handle, or search term")

    sub.add_parser("remove",      help="Unsubscribe via fzf picker")

    ip = sub.add_parser("import", help="Import subscriptions from file")
    ip.add_argument("file", help=".opml / .json / text file")

    sub.add_parser("subs",        help="List subscriptions")
    sub.add_parser("config",      help="Show configuration paths and settings")
    sub.add_parser("init-config", help="Write default config.json")

    args   = parser.parse_args()
    config = load_config()

    for d in (CONFIG_DIR, CACHE_DIR, FEED_CACHE):
        d.mkdir(parents=True, exist_ok=True)
    _load_watched()

    cmd = args.cmd

    if cmd == "config":
        cmd_show_config(config)
        return
    if cmd == "init-config":
        save_default_config()
        return

    subs = load_subs()

    if cmd == "subs":
        cmd_subs(subs)
        return
    if cmd == "remove":
        cmd_remove(subs)
        return
    if cmd == "import":
        cmd_import(args, subs)
        return
    if cmd == "add":
        cmd_add(args, config, subs)
        return
    if cmd == "search":
        cmd_search(args, config, subs)
        return

    # Default: browse
    cmd_browse(args, config, subs)


if __name__ == "__main__":
    main()
