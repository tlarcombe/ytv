VERSION = "2.2.1"

# ─── Paths ───────────────────────────────────────────────────────────────────
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "ytv"
CACHE_DIR  = Path(os.environ.get("XDG_CACHE_HOME",  Path.home() / ".cache"))  / "ytv"
FEED_CACHE = CACHE_DIR / "feeds"
SUBS_FILE    = CONFIG_DIR / "subscriptions.json"
WATCHED_FILE = CONFIG_DIR / "watched.json"
_SOCK_PATH   = "/tmp/ytv-mpv.sock"

DEFAULT_CONFIG: dict = {
    "cache_ttl":      3600,
    "max_videos":     500,
    "fetch_workers":  20,
    "mpv_geometry":   "50%x50%-0+0",
    "mpv_extra_args": [],
    "quality":        "bestvideo[height<=720]+bestaudio/best[height<=720]",
    "audio_quality":  "bestaudio/best",
    "volume":         100,
    "sticky_window":  False,
}

# ─── Watched state (module-level, loaded once at startup) ────────────────────
_watched:       set[str]  = set()
_mpv_mode:      dict      = {"audio_only": None}  # tracks current mpv audio/video mode
_autoplay_queue: list[str] = []
_autoplay_lock  = threading.Lock()

# ─── Config ──────────────────────────────────────────────────────────────────

def load_config() -> dict:
    config = dict(DEFAULT_CONFIG)
    config_file = CONFIG_DIR / "config.json"
    if config_file.exists():
        try:
            with open(config_file) as f:
                config.update(json.load(f))
        except (json.JSONDecodeError, OSError) as e:
            warn(f"Config error: {e}")
    return config


def save_default_config() -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    config_file = CONFIG_DIR / "config.json"
    if config_file.exists():
        warn(f"Config already exists: {config_file}")
        return
    with open(config_file, "w") as f:
        json.dump(DEFAULT_CONFIG, f, indent=2)
    info(f"Config written to {config_file}")

# ─── Subscriptions ───────────────────────────────────────────────────────────

def _load_subs_file() -> list[dict]:
    if SUBS_FILE.exists():
        try:
            data = json.loads(SUBS_FILE.read_text())
            if isinstance(data, list):
                return data
        except (json.JSONDecodeError, OSError):
            pass
    return []


def save_subs(subs: list[dict]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    SUBS_FILE.write_text(json.dumps(subs, indent=2))


def add_sub(subs: list[dict], channel_id: str, name: str) -> bool:
    """Add subscription if not already present. Returns True if added."""
    if any(s["id"] == channel_id for s in subs):
        return False
    subs.append({"id": channel_id, "name": name})
    return True


def _dedup(subs: list[dict]) -> list[dict]:
    seen: set[str] = set()
    result = []
    for s in subs:
        cid = s.get("id", "")
        if cid and cid not in seen:
            seen.add(cid)
            result.append(s)
    return result

# ─── Import helpers ──────────────────────────────────────────────────────────
# These parsers handle several subscription export formats.
# First-run auto-migration silently checks known locations for existing data.

def _import_ndjson(content: str) -> list[dict]:
    """NDJSON subscription store — one JSON object per line."""
    subs = []
    for line in content.strip().splitlines():
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(obj.get("subscriptions"), list):
            for s in obj["subscriptions"]:
                cid = s.get("id", "")
                if cid:
                    subs.append({"id": cid, "name": s.get("name", cid)})
    return _dedup(subs)


def _import_opml(content: str) -> list[dict]:
    """YouTube OPML subscription export."""
    subs = []
    try:
        root = ET.fromstring(content)
    except ET.ParseError:
        return []
    for outline in root.iter("outline"):
        xml_url = outline.get("xmlUrl", "")
        name    = outline.get("title") or outline.get("text", "")
        if "channel_id=" in xml_url and name:
            cid = xml_url.split("channel_id=")[-1].split("&")[0]
            if cid:
                subs.append({"id": cid, "name": name})
    return _dedup(subs)


def import_from_file(path: Path) -> list[dict]:
    """Auto-detect format and return subscriptions from file."""
    try:
        content = path.read_text(errors="replace").strip()
    except OSError as e:
        die(f"Cannot read {path}: {e}")
    if not content:
        return []
    if content.startswith("<"):
        return _import_opml(content)
    if content.startswith("{"):
        return _import_ndjson(content)
    try:
        data = json.loads(content)
        if isinstance(data, list):
            result = []
            for item in data:
                if isinstance(item, dict) and item.get("id"):
                    result.append({"id": item["id"], "name": item.get("name", item["id"])})
                elif isinstance(item, str) and item.strip():
                    result.append({"id": item.strip(), "name": item.strip()})
            return _dedup(result)
    except json.JSONDecodeError:
        pass
    # Plain text: one channel URL / ID per line
    subs = []
    for line in content.splitlines():
        line = line.strip()
        if line and not line.startswith("#"):
            subs.append({"id": line, "name": line})
    return _dedup(subs)


# Known locations to check for existing subscription data on first run.
_MIGRATION_CANDIDATES = [
    Path.home() / ".config" / "FreeTube" / "profiles.db",
]


def load_subs() -> list[dict]:
    """Load subscriptions; auto-migrate from known sources on first run."""
    subs = _load_subs_file()
    if subs:
        return subs
    for path in _MIGRATION_CANDIDATES:
        if path.exists():
            try:
                imported = import_from_file(path)
                if imported:
                    save_subs(imported)
                    info(f"Imported {len(imported)} subscriptions → {SUBS_FILE}")
                    return imported
            except Exception:
                pass
    return []

# ─── Channel resolution (yt-dlp) ─────────────────────────────────────────────

def resolve_channel(url: str) -> dict | None:
    """Resolve a YouTube URL to {id, name} using yt-dlp."""
    cmd = [
        "yt-dlp", "--playlist-items=0",
        "--print=%(channel_id)s", "--print=%(channel)s",
        "--quiet", "--no-warnings", url,
    ]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
        lines = [l for l in r.stdout.strip().splitlines() if l and l != "NA"]
        if len(lines) >= 2:
            return {"id": lines[0], "name": lines[1]}
    except Exception:
        pass
    return None

# ─── Feed fetching (RSS) ─────────────────────────────────────────────────────

_FEED_URL  = "https://www.youtube.com/feeds/videos.xml?channel_id={channel_id}"
_UA        = "Mozilla/5.0 (X11; Linux x86_64; rv:120.0) Gecko/20100101 Firefox/120.0"


def fetch_channel_feed(
    channel_id: str, name: str, cache_ttl: int, force: bool = False
) -> tuple[str, str] | None:
    """Fetch RSS feed. Returns (name, xml) or None. Falls back to stale cache."""
    cache = FEED_CACHE / f"{channel_id}.xml"
    if not force and cache.exists():
        if time.time() - cache.stat().st_mtime < cache_ttl:
            try:
                return name, cache.read_text()
            except OSError:
                pass
    try:
        req = urllib.request.Request(
            _FEED_URL.format(channel_id=channel_id), headers={"User-Agent": _UA}
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            xml = resp.read().decode("utf-8", errors="replace")
        FEED_CACHE.mkdir(parents=True, exist_ok=True)
        tmp = cache.with_suffix(".tmp")
        tmp.write_text(xml)
        tmp.rename(cache)
        return name, xml
    except Exception:
        if cache.exists():
            try:
                return name, cache.read_text()
            except OSError:
                pass
        return None


_NS = {
    "atom":  "http://www.w3.org/2005/Atom",
    "yt":    "http://www.youtube.com/xml/schemas/2015",
    "media": "http://search.yahoo.com/mrss/",
}


def _fmt_views(v: str) -> str:
    try:
        n = int(v)
    except (ValueError, TypeError):
        return ""
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.0f}K"
    return str(n)


def parse_feed(xml: str, channel_name: str) -> list[dict]:
    """Parse YouTube Atom feed. Returns list of video dicts."""
    try:
        root = ET.fromstring(xml)
    except ET.ParseError:
        return []
    feed_cid_el = root.find("yt:channelId", _NS)
    feed_cid = (feed_cid_el.text or "").strip() if feed_cid_el is not None else ""

    videos = []
    for entry in root.findall("atom:entry", _NS):
        try:
            vid_el = entry.find("yt:videoId", _NS)
            ttl_el = entry.find("atom:title", _NS)
            pub_el = entry.find("atom:published", _NS)
            cid_el = entry.find("yt:channelId", _NS)
            if vid_el is None or ttl_el is None:
                continue
            video_id   = (vid_el.text or "").strip()
            title      = (ttl_el.text or "Untitled").strip()
            channel_id = (cid_el.text or feed_cid).strip() if cid_el is not None else feed_cid

            pub_ts = 0.0
            pub_date = ""
            if pub_el is not None and pub_el.text:
                try:
                    dt = datetime.fromisoformat(pub_el.text.replace("Z", "+00:00"))
                    pub_ts   = dt.timestamp()
                    pub_date = dt.strftime("%Y-%m-%d")
                except ValueError:
                    pass

            # Skip YouTube Shorts (vertical aspect ratio or #shorts tag)
            if "#short" in title.lower():
                continue
            mg = entry.find("media:group", _NS)
            if mg is not None:
                mc = mg.find("media:content", _NS)
                if mc is not None:
                    try:
                        w = int(mc.get("width") or 0)
                        h = int(mc.get("height") or 0)
                        if h > w > 0:  # vertical = Short
                            continue
                    except (ValueError, TypeError):
                        pass

            views = ""
            if mg is not None:
                st = mg.find("media:community/media:statistics", _NS)
                if st is not None:
                    views = _fmt_views(st.get("views", ""))

            videos.append({
                "url":        f"https://www.youtube.com/watch?v={video_id}",
                "id":         video_id,
                "title":      title,
                "channel":    channel_name,
                "channel_id": channel_id,
                "date":       pub_date,
                "ts":         pub_ts,
                "views":      views,
            })
        except Exception:
            continue
    return videos


def get_all_videos(
    subs: list[dict], config: dict, force: bool = False, verbose: bool = False
) -> list[dict]:
    """Fetch and aggregate feeds from all subscriptions in parallel."""
    total = len(subs)
    all_videos: list[dict] = []
    done = 0

    with ThreadPoolExecutor(max_workers=config["fetch_workers"]) as pool:
        futures = {
            pool.submit(fetch_channel_feed, s["id"], s["name"], config["cache_ttl"], force): s
            for s in subs
        }
        for future in as_completed(futures):
            done += 1
            if verbose:
                eprint(f"\r  {done}/{total} channels fetched...", end="")
            r = future.result()
            if r:
                all_videos.extend(parse_feed(r[1], r[0]))

    if verbose:
        eprint()
    all_videos.sort(key=lambda v: v["ts"], reverse=True)
    return all_videos[: config["max_videos"]]

# ─── yt-dlp helpers (search / channel deep-dive) ─────────────────────────────

def search_youtube(query: str, config: dict, limit: int = 25) -> list[dict]:
    """Search YouTube via yt-dlp. Returns video list."""
    cmd = [
        "yt-dlp", "--flat-playlist", f"--playlist-end={limit}",
        "--print=%(title)s\t%(id)s\t%(channel_id)s\t%(channel)s\t%(view_count)s\t%(webpage_url)s",
        "--quiet", "--no-warnings",
        f"ytsearch{limit}:{query}",
    ]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return []
    videos = []
    for line in r.stdout.strip().splitlines():
        parts = line.split("\t")
        if len(parts) < 5:
            continue
        title, vid_id, cid, channel, views = (p if p != "NA" else "" for p in parts[:5])
        webpage_url = parts[5] if len(parts) > 5 else ""
        if not vid_id or "/shorts/" in webpage_url:
            continue
        videos.append({
            "url":        f"https://www.youtube.com/watch?v={vid_id}",
            "id":         vid_id,
            "title":      title,
            "channel":    channel,
            "channel_id": cid,
            "date":       "",
            "ts":         0.0,
            "views":      _fmt_views(views) if views else "",
        })
    return videos


def fetch_channel_yt_dlp(channel_id: str, name: str, limit: int = 30) -> list[dict]:
    """Fetch recent videos from a channel via yt-dlp flat-playlist."""
    cmd = [
        "yt-dlp", "--flat-playlist", "--lazy-playlist",
        f"--playlist-end={limit}",
        "--extractor-args=youtubetab:approximate_date",
        "--print=%(title)s\t%(id)s\t%(timestamp)s\t%(channel)s\t%(view_count)s\t%(webpage_url)s",
        "--quiet", "--no-warnings",
        f"https://www.youtube.com/channel/{channel_id}/videos",
    ]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return []
    videos = []
    for line in r.stdout.strip().splitlines():
        parts = line.split("\t")
        if len(parts) < 5:
            continue
        title, vid_id, ts_str, channel, views = (p if p != "NA" else "" for p in parts[:5])
        webpage_url = parts[5] if len(parts) > 5 else ""
        if not vid_id or "/shorts/" in webpage_url:
            continue
        pub_ts = 0.0
        pub_date = ""
        try:
            pub_ts   = float(ts_str)
            pub_date = datetime.fromtimestamp(pub_ts, tz=timezone.utc).strftime("%Y-%m-%d")
        except (ValueError, OSError, OverflowError):
            pass
        videos.append({
            "url":        f"https://www.youtube.com/watch?v={vid_id}",
            "id":         vid_id,
            "title":      title,
            "channel":    channel or name,
            "channel_id": channel_id,
            "date":       pub_date,
            "ts":         pub_ts,
            "views":      _fmt_views(views) if views else "",
        })
    return videos

# ─── Watched history ─────────────────────────────────────────────────────────

def _load_watched() -> None:
    """Populate _watched from disk; called once at startup."""
    if WATCHED_FILE.exists():
        try:
            data = json.loads(WATCHED_FILE.read_text())
            if isinstance(data, list):
                _watched.update(data)
        except Exception:
            pass


def _mark_played(urls: list[str]) -> None:
    """Record video IDs as watched and persist to disk."""
    ids = [u.split("v=")[-1].split("&")[0] for u in urls if "v=" in u]
    if not ids:
        return
    _watched.update(ids)
    try:
        WATCHED_FILE.write_text(json.dumps(list(_watched)))
    except Exception:
        pass

def _next_unwatched(videos: list[dict], sel_urls: list[str], limit: int = 10) -> list[str]:
    """Return up to `limit` unwatched video URLs immediately following the selection."""
    if not sel_urls:
        return []
    sel_set = set(sel_urls)
    last_idx = -1
    for i, v in enumerate(videos):
        if v["url"] in sel_set:
            last_idx = i
    if last_idx < 0:
        return []
    return [
        v["url"] for v in videos[last_idx + 1:]
        if v.get("id") not in _watched
    ][:limit]

# ─── mpv IPC helpers ─────────────────────────────────────────────────────────

def _send_ipc(command: list) -> bool:
    """Send a JSON command to the running mpv via IPC socket. Returns True on success."""
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(1.0)
        s.connect(_SOCK_PATH)
        s.sendall((json.dumps({"command": command}) + "\n").encode())
        s.close()
        return True
    except Exception:
        return False


def _query_volume() -> int | None:
    """Read current mpv volume via IPC. Returns 0-200 or None."""
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(1.0)
        s.connect(_SOCK_PATH)
        s.sendall(b'{"command":["get_property","volume"]}\n')
        data = b""
        while b"\n" not in data:
            chunk = s.recv(4096)
            if not chunk:
                break
            data += chunk
        s.close()
        msg = json.loads(data.decode().strip().splitlines()[0])
        vol = msg.get("data")
        if vol is not None:
            return max(0, min(200, round(vol)))
    except Exception:
        pass
    return None


def _save_volume(vol: int, config: dict) -> None:
    """Update in-memory config and persist volume to config.json."""
    config["volume"] = vol
    config_file = CONFIG_DIR / "config.json"
    try:
        saved: dict = {}
        if config_file.exists():
            saved = json.loads(config_file.read_text())
        saved["volume"] = vol
        config_file.write_text(json.dumps(saved, indent=2))
    except Exception:
        pass


def _monitor_mpv(config: dict) -> None:
    """
    Daemon thread: subscribe to mpv's volume property via IPC.
    When mpv exits (connection drops), save the last observed volume.
    Also handles auto-play: when a file ends naturally, plays next from queue.
    """
    # Wait up to 3 s for mpv to create its IPC socket
    for _ in range(30):
        if Path(_SOCK_PATH).exists():
            break
        time.sleep(0.1)
    else:
        return

    last_vol = None
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(2.0)
        s.connect(_SOCK_PATH)
        s.sendall(b'{"command":["observe_property",1,"volume"]}\n')
        buf = ""
        while True:
            try:
                data = s.recv(4096)
            except socket.timeout:
                continue
            if not data:
                break  # mpv closed its end
            buf += data.decode("utf-8", errors="replace")
            while "\n" in buf:
                line, buf = buf.split("\n", 1)
                try:
                    msg = json.loads(line)
                    event = msg.get("event")
                    if (event == "property-change"
                            and msg.get("name") == "volume"
                            and msg.get("data") is not None):
                        last_vol = msg["data"]
                    elif event == "end-file" and msg.get("reason") == "eof":
                        with _autoplay_lock:
                            if _autoplay_queue:
                                next_url = _autoplay_queue.pop(0)
                                _mark_played([next_url])
                                _send_ipc(["loadfile", next_url, "replace"])
                except (json.JSONDecodeError, KeyError):
                    pass
    except Exception:
        pass

    if last_vol is not None:
        _save_volume(max(0, min(200, round(last_vol))), config)

# ─── fzf interface ───────────────────────────────────────────────────────────
# Line format (6 tab-separated fields):
#   1: url        ← hidden
#   2: channel_id ← hidden
#   3: date       ← hidden (available in preview via {3})
#   4: channel    ← hidden (available in preview via {4})
#   5: views      ← hidden (available in preview via {5})
#   6: display    ← shown (--with-nth=6)

_PREVIEW = "printf 'Channel:  {4}\\nDate:     {3}\\nViews:    {5}\\nURL:      {1}'"

_MAIN_HDR   = (
    "ENTER:play  CTRL-A:audio  CTRL-Y:copy URL  "
    "CTRL-S:search  CTRL-N:more from channel  CTRL-R:refresh  TAB:multi-select"
)
_EXTRA_HDR  = (
    "ENTER:play  CTRL-A:audio  CTRL-Y:copy URL  "
    "CTRL-B:subscribe to channel  TAB:multi-select  ESC:back"
)


def _fmt_line(v: dict) -> str:
    date    = v.get("date", "")
    channel = v.get("channel", "")[:26].ljust(26)
    views   = v.get("views", "").rjust(6) if v.get("views") else " " * 6
    title   = v.get("title", "").replace("\t", " ")
    display = f"{date}  {channel}  {views}  {title}"
    if v.get("id") in _watched:
        display = f"\033[2m{display}\033[0m"  # dim watched videos
    return "\t".join([
        v.get("url", ""),
        v.get("channel_id", ""),
        v.get("date", ""),
        v.get("channel", ""),
        v.get("views", ""),
        display,
    ])


def run_fzf(
    videos: list[dict],
    prompt: str = "ytv> ",
    header: str = "",
    extra_keys: list[str] | None = None,
    start_pos: int = 0,
) -> tuple[str, list[str]] | None:
    """
    Show video list in fzf.
    Returns (key_pressed, [raw_tab_separated_lines]) or None if cancelled.
    """
    if not videos:
        return None
    lines = "\n".join(_fmt_line(v) for v in videos)
    keys  = ["enter", "ctrl-a", "ctrl-y", "ctrl-r"] + (extra_keys or [])
    cmd   = [
        "fzf",
        "--ansi",
        "--multi",
        "--delimiter=\t",
        "--with-nth=6",
        "--layout=reverse",
        "--info=inline",
        f"--header={header}",
        f"--prompt={prompt}",
        f"--expect={','.join(keys)}",
        f"--preview={_PREVIEW}",
        "--preview-window=up:4:wrap",
    ]
    if start_pos > 0:
        cmd.append(f"--bind=load:pos({start_pos})")
    try:
        r = subprocess.run(cmd, input=lines, capture_output=True, text=True)
    except FileNotFoundError:
        die("fzf not found. Install: sudo pacman -S fzf")
    if r.returncode not in (0, 1):
        return None
    output = r.stdout.strip()
    if not output:
        return None
    output_lines = output.splitlines()
    key      = output_lines[0] if output_lines else "enter"
    selected = output_lines[1:] if len(output_lines) > 1 else []
    return key, selected


def _urls(lines: list[str]) -> list[str]:
    return [l.split("\t")[0] for l in lines if l]


def _channel_of(lines: list[str]) -> tuple[str, str]:
    """Return (channel_id, channel_name) from the first line."""
    if not lines:
        return "", ""
    parts = lines[0].split("\t")
    return (parts[1] if len(parts) > 1 else ""), (parts[3] if len(parts) > 3 else "")

# ─── Player ──────────────────────────────────────────────────────────────────

def play_video(
    urls: list[str], audio_only: bool, config: dict, upcoming: list[str] | None = None
) -> None:
    global _autoplay_queue
    sock_exists = Path(_SOCK_PATH).exists()

    if sock_exists and _mpv_mode["audio_only"] == audio_only:
        # Save current volume before replacing, then load new video in-place
        vol = _query_volume()
        if vol is not None:
            _save_volume(vol, config)
        if _send_ipc(["loadfile", urls[0], "replace"]):
            for url in urls[1:]:
                _send_ipc(["loadfile", url, "append"])
            with _autoplay_lock:
                _autoplay_queue = list(upcoming or [])
            _mark_played(urls)
            return

    # Mode switch (audio↔video) or first play: quit running mpv if any
    if sock_exists:
        vol = _query_volume()
        if vol is not None:
            _save_volume(vol, config)
        _send_ipc(["quit"])
        for _ in range(20):          # wait up to 2 s for socket to disappear
            if not Path(_SOCK_PATH).exists():
                break
            time.sleep(0.1)
    # Remove stale socket file so mpv can bind a fresh one
    try:
        Path(_SOCK_PATH).unlink(missing_ok=True)
    except OSError:
        pass

    # Launch new mpv with IPC socket and saved volume
    cmd = [
        "mpv",
        f"--input-ipc-server={_SOCK_PATH}",
        f"--volume={config.get('volume', 100)}",
        "--idle=yes",   # stay alive after playlist ends so auto-play IPC works
    ]
    if audio_only:
        cmd += ["--no-video", f"--ytdl-format={config['audio_quality']}"]
    else:
        cmd += [f"--geometry={config['mpv_geometry']}", f"--ytdl-format={config['quality']}"]
    cmd += ["--title=ytv"] + (config.get("mpv_extra_args") or []) + ["--"] + urls

    with _autoplay_lock:
        _autoplay_queue = list(upcoming or [])
    _mpv_mode["audio_only"] = audio_only
    try:
        subprocess.Popen(
            cmd,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        die("mpv not found. Install: sudo pacman -S mpv")

    # Daemon thread: observe volume + handle auto-play, save volume when mpv exits
    threading.Thread(target=_monitor_mpv, args=(config,), daemon=True).start()
    # Daemon thread: make window sticky if configured
    if not audio_only and config.get("sticky_window"):
        threading.Thread(target=_apply_sticky, daemon=True).start()
    _mark_played(urls)


def _apply_sticky() -> None:
    """Daemon thread: wait for the ytv mpv window and make it sticky (all workspaces)."""
    for cmd in (
        ["wmctrl", "-r", "ytv", "-b", "add,sticky"],
        ["xdotool", "search", "--name", "ytv", "windowstate", "--add", "STICKY"],
    ):
        for _ in range(50):   # poll up to 5 s for the window to appear
            time.sleep(0.1)
            try:
                r = subprocess.run(cmd, capture_output=True)
                if r.returncode == 0:
                    return
            except FileNotFoundError:
                break   # tool not available — try next


def copy_to_clipboard(text: str) -> bool:
    for cmd in (
        ["wl-copy"],
        ["xclip", "-selection", "clipboard"],
        ["xsel", "--clipboard", "--input"],
    ):
        try:
            subprocess.run(
                cmd, input=text, text=True, check=True,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            return True
        except (FileNotFoundError, subprocess.CalledProcessError):
            continue
    return False

# ─── Utilities ───────────────────────────────────────────────────────────────

def eprint(*args, end="\n"):
    print(*args, end=end, file=sys.stderr)

def info(msg: str):  eprint(f"\033[32m✓\033[0m {msg}")
def warn(msg: str):  eprint(f"\033[33m!\033[0m {msg}")
def die(msg: str):   eprint(f"\033[31merror:\033[0m {msg}"); sys.exit(1)

# ─── Auxiliary fzf panel (search results / more-from-channel) ────────────────

def show_panel(videos: list[dict], subs: list[dict], config: dict, title: str) -> None:
    """
    Show a secondary video panel (search results, channel deep-dive, etc.).
    Supports CTRL-B to subscribe to a channel and CTRL-A for audio.
    Returns after user exits or takes an action.
    """
    while True:
        result = run_fzf(
            videos,
            prompt=f"{title}> ",
            header=_EXTRA_HDR,
            extra_keys=["ctrl-b"],
        )
        if result is None:
            break

        key, lines = result
        urls = _urls(lines)

        if key == "ctrl-b":
            cid, cname = _channel_of(lines)
            if cid:
                if add_sub(subs, cid, cname):
                    save_subs(subs)
                    info(f"Subscribed to {cname}")
                else:
                    warn(f"Already subscribed to {cname}")
            break

        if not urls:
            break

        if key == "ctrl-y":
            if copy_to_clipboard("\n".join(urls)):
                info(f"Copied {len(urls)} URL(s) to clipboard.")
            else:
                warn("Clipboard unavailable. Install wl-clipboard or xclip.")
                print("\n".join(urls))
            continue

        if key in ("enter", "ctrl-a"):
            upcoming = _next_unwatched(videos, urls)
            play_video(urls, audio_only=(key == "ctrl-a"), config=config, upcoming=upcoming)
            continue  # stay in panel after playing

# ─── Commands ────────────────────────────────────────────────────────────────

def cmd_browse(args, config: dict, subs: list[dict]) -> None:
    if not subs:
        die("No subscriptions. Add channels with:\n  ytv add <channel-url-or-search-term>")

    force   = getattr(args, "refresh", False)
    verbose = getattr(args, "verbose", False)
    audio   = getattr(args, "audio",   False)

    eprint(f"ytv {VERSION}  │  {len(subs)} subscriptions  │  fetching feeds...")
    videos = get_all_videos(subs, config, force=force, verbose=verbose)
    eprint("\r\033[K", end="")

    last_pos = 0  # cursor position to restore in fzf on next iteration

    while True:
        if not videos:
            die("No videos found. Run: ytv -r")

        result = run_fzf(videos, header=_MAIN_HDR, extra_keys=["ctrl-s", "ctrl-n"], start_pos=last_pos)
        if result is None:
            break

        key, lines = result

        # Remember where the cursor was so we return to the same item
        if lines:
            sel_url = lines[0].split("\t")[0]
            for i, v in enumerate(videos):
                if v["url"] == sel_url:
                    last_pos = i + 1  # fzf pos() is 1-based
                    break

        # ── Refresh ───────────────────────────────────────────────────────────
        if key == "ctrl-r":
            eprint("Refreshing feeds...")
            videos = get_all_videos(subs, config, force=True, verbose=verbose)
            eprint("\r\033[K", end="")
            last_pos = 0
            continue

        # ── Search ────────────────────────────────────────────────────────────
        if key == "ctrl-s":
            try:
                query = input("Search YouTube: ").strip()
            except (EOFError, KeyboardInterrupt):
                continue
            if not query:
                continue
            eprint(f"Searching '{query}'...")
            results = search_youtube(query, config)
            eprint("\r\033[K", end="")
            if not results:
                warn("No results found.")
            else:
                show_panel(results, subs, config, f"Search: {query}")
            continue

        # ── More from channel ─────────────────────────────────────────────────
        if key == "ctrl-n":
            cid, cname = _channel_of(lines)
            if not cid:
                warn("No channel information available for this video.")
                continue
            eprint(f"Loading videos from {cname}...")
            more = fetch_channel_yt_dlp(cid, cname)
            eprint("\r\033[K", end="")
            if not more:
                warn(f"Could not load videos from {cname}.")
            else:
                show_panel(more, subs, config, f"More: {cname}")
            continue

        # ── Play / copy ───────────────────────────────────────────────────────
        urls = _urls(lines)
        if not urls:
            continue

        if key == "ctrl-y":
            if copy_to_clipboard("\n".join(urls)):
                info(f"Copied {len(urls)} URL(s) to clipboard.")
            else:
                warn("Clipboard unavailable. Install wl-clipboard or xclip.")
                print("\n".join(urls))
            continue

        if key in ("enter", "ctrl-a") or audio:
            upcoming = _next_unwatched(videos, urls)
            play_video(urls, audio_only=(key == "ctrl-a" or audio), config=config, upcoming=upcoming)
            continue  # ← stay in ytv after launching mpv


def cmd_search(args, config: dict, subs: list[dict]) -> None:
    query = " ".join(args.query) if args.query else ""
    if not query:
        try:
            query = input("Search YouTube: ").strip()
        except (EOFError, KeyboardInterrupt):
            return
    if not query:
        return
    eprint(f"Searching '{query}'...")
    results = search_youtube(query, config)
    eprint("\r\033[K", end="")
    if not results:
        die("No results found.")
    show_panel(results, subs, config, f"Search: {query}")


def cmd_add(args, config: dict, subs: list[dict]) -> None:
    target = (getattr(args, "channel", None) or "").strip()
    if not target:
        try:
            target = input("Channel URL, handle (@name), or search term: ").strip()
        except (EOFError, KeyboardInterrupt):
            return
    if not target:
        return

    is_url = (
        "youtube.com" in target
        or "youtu.be" in target
        or target.startswith("http")
        or target.startswith("@")
    )

    if is_url:
        if not target.startswith("http"):
            target = f"https://www.youtube.com/{target}"
        eprint("Resolving channel...")
        resolved = resolve_channel(target)
        if not resolved:
            die(f"Could not resolve channel: {target}")
        cid, cname = resolved["id"], resolved["name"]
    else:
        # Search and let user pick from unique channels in results
        eprint(f"Searching for '{target}'...")
        results = search_youtube(target, config, limit=20)
        eprint("\r\033[K", end="")
        if not results:
            die("No results found.")
        seen: dict[str, str] = {}
        for v in results:
            cid_v = v.get("channel_id", "")
            if cid_v and cid_v not in seen:
                seen[cid_v] = v.get("channel", cid_v)
        if not seen:
            die("Could not extract channel info from search results.")
        chan_lines = [f"{cid}\t{name}" for cid, name in seen.items()]
        r = subprocess.run(
            ["fzf",
             "--prompt=Subscribe to> ",
             "--header=Select a channel to subscribe (ENTER to confirm)",
             "--delimiter=\t",
             "--with-nth=2"],
            input="\n".join(chan_lines),
            capture_output=True, text=True,
        )
        if r.returncode != 0 or not r.stdout.strip():
            return
        parts = r.stdout.strip().split("\t")
        cid   = parts[0]
        cname = parts[1] if len(parts) > 1 else parts[0]

    if add_sub(subs, cid, cname):
        save_subs(subs)
        info(f"Subscribed to {cname}  ({cid})")
    else:
        warn(f"Already subscribed to {cname}")


def cmd_remove(subs: list[dict]) -> None:
    if not subs:
        die("No subscriptions to remove.")
    lines = [
        f"{s['id']}\t{s['name']}"
        for s in sorted(subs, key=lambda s: s["name"].lower())
    ]
    r = subprocess.run(
        ["fzf",
         "--multi",
         "--prompt=Remove> ",
         "--header=TAB to select channels to unsubscribe, ENTER to confirm",
         "--delimiter=\t",
         "--with-nth=2"],
        input="\n".join(lines),
        capture_output=True, text=True,
    )
    if r.returncode != 0 or not r.stdout.strip():
        return
    to_remove = {line.split("\t")[0] for line in r.stdout.strip().splitlines()}
    original  = len(subs)
    subs[:]   = [s for s in subs if s["id"] not in to_remove]
    removed   = original - len(subs)
    if removed:
        save_subs(subs)
        info(f"Removed {removed} subscription(s). {len(subs)} remaining.")


def cmd_import(args, subs: list[dict]) -> None:
    path = Path(args.file).expanduser()
    if not path.exists():
        die(f"File not found: {path}")
    imported = import_from_file(path)
    if not imported:
        die("No subscriptions found in file.")
    added = sum(1 for s in imported if add_sub(subs, s["id"], s["name"]))
    if added:
        save_subs(subs)
        info(f"Imported {added} new subscription(s). Total: {len(subs)}")
    else:
        info("All channels already subscribed. No changes made.")


def cmd_subs(subs: list[dict]) -> None:
    if not subs:
        eprint("No subscriptions. Add channels with: ytv add <channel>")
        return
    for s in sorted(subs, key=lambda s: s["name"].lower()):
        print(f"{s['id']}  {s['name']}")
    eprint(f"\nTotal: {len(subs)} subscriptions")


